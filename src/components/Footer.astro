---
import { SITE, SOCIALS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap foot">
    <div class="foot-lead">
      <p class="eyebrow">Get in touch</p>
      <p class="foot-line">
        Building something at the edge of AI and platform engineering?
        <a href="mailto:hello@mark-thebault.pro">Let’s talk.</a>
      </p>
    </div>

    <ul class="foot-socials">
      {
        SOCIALS.map((s) => (
          <li>
            <a href={s.href} rel="me noopener" target={s.label === 'Email' ? undefined : '_blank'}>
              <span class="s-label">{s.label}</span>
              <span class="s-handle mono">{s.handle}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="wrap foot-base">
    <span class="mono">© {year} {SITE.name}</span>
    <span class="mono dim">{SITE.drawingNo} · Built with Astro</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--hairline);
    margin-top: 6rem;
    padding-top: 3.5rem;
    padding-bottom: 2rem;
  }
  .foot {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 48rem) {
    .foot {
      grid-template-columns: 1.2fr 1fr;
      gap: 3rem;
    }
  }
  .foot-line {
    font-family: var(--font-display);
    font-size: var(--step-1);
    line-height: 1.3;
    margin-top: 0.9rem;
    color: var(--ink);
    max-width: 22ch;
  }
  .foot-line a {
    text-decoration: underline;
    text-decoration-color: var(--blueprint);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 0.2em;
  }
  .foot-socials {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    align-self: start;
  }
  .foot-socials li {
    border-top: 1px solid var(--hairline);
  }
  .foot-socials li:nth-child(odd) {
    border-right: 1px solid var(--hairline);
    padding-right: 1rem;
  }
  .foot-socials li:nth-child(even) {
    padding-left: 1rem;
  }
  .foot-socials a {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-block: 0.85rem;
    color: var(--ink-soft);
  }
  .foot-socials a:hover {
    color: var(--blueprint);
  }
  .s-label {
    font-size: 0.95rem;
    color: var(--ink);
  }
  .foot-socials a:hover .s-label {
    color: var(--blueprint);
  }
  .s-handle {
    color: var(--taupe);
    font-size: 0.72rem;
  }
  .foot-base {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 3rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--hairline);
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .foot-base .mono {
    font-size: 0.72rem;
    color: var(--taupe);
  }
  .dim {
    opacity: 0.8;
  }
</style>
