---
import { SITE, NAV } from '../consts';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-header">
  <div class="wrap bar">
    <a href="/" class="brand" aria-label={`${SITE.name} — home`}>
      <span class="brand-mark mono">MT</span>
      <span class="brand-name">{SITE.name}</span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav">
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={['nav-link', { active: isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--paper) 86%, transparent);
    backdrop-filter: saturate(1.1) blur(8px);
    border-bottom: 1px solid var(--hairline);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
    gap: 1rem;
  }
  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.7rem;
    color: var(--ink);
  }
  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 1.9rem;
    height: 1.9rem;
    border: 1px solid var(--ink);
    color: var(--ink);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    transform: translateY(0.1rem);
    transition: all 0.3s var(--ease);
  }
  .brand:hover .brand-mark {
    background: var(--blueprint);
    border-color: var(--blueprint);
    color: var(--paper);
  }
  .brand-name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .nav {
    list-style: none;
    display: flex;
    gap: 1.6rem;
    align-items: center;
  }
  .nav-link {
    font-size: 0.92rem;
    color: var(--ink-soft);
    padding-block: 0.4rem;
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--blueprint);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease);
  }
  .nav-link:hover {
    color: var(--ink);
  }
  .nav-link:hover::after,
  .nav-link.active::after {
    transform: scaleX(1);
  }
  .nav-link.active {
    color: var(--ink);
  }
  @media (max-width: 34rem) {
    .brand-name {
      display: none;
    }
    .nav {
      gap: 1.1rem;
    }
  }
</style>
