---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
}

const { title, description, image, type, schema, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      schema={schema}
      noindex={noindex}
    />
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .skip {
    position: absolute;
    left: 1rem;
    top: -3rem;
    background: var(--ink);
    color: var(--paper);
    padding: 0.5rem 0.9rem;
    z-index: 100;
    transition: top 0.2s var(--ease);
  }
  .skip:focus {
    top: 1rem;
  }
</style>
