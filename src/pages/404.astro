---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="This page could not be found." noindex={true}>
  <section class="wrap nf">
    <p class="eyebrow">Error 404</p>
    <h1 class="nf-title">This sheet isn’t in the set.</h1>
    <p class="nf-body">
      The page you’re looking for was moved, renamed, or never drawn. Let’s get
      you back to something real.
    </p>
    <div class="nf-cta">
      <a href="/" class="btn">Return home</a>
      <a href="/articles/" class="btn btn-ghost">Browse writing</a>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    padding-top: clamp(4rem, 14vh, 9rem);
    padding-bottom: 6rem;
  }
  .nf-title {
    font-size: var(--step-3);
    margin-top: 1.2rem;
    max-width: 16ch;
  }
  .nf-body {
    margin-top: 1.4rem;
    color: var(--ink-soft);
    font-size: var(--step-1);
    max-width: 42ch;
  }
  .nf-cta {
    margin-top: 2.2rem;
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.3rem;
    font-size: 0.92rem;
    font-weight: 500;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    transition: all 0.25s var(--ease);
  }
  .btn:hover {
    background: var(--blueprint);
    border-color: var(--blueprint);
    color: var(--paper);
  }
  .btn-ghost {
    background: none;
    border-color: var(--hairline-strong);
    color: var(--ink);
  }
  .btn-ghost:hover {
    background: none;
    border-color: var(--blueprint);
    color: var(--blueprint);
  }
</style>
